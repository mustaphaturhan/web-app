SKIP_PREFLIGHT_CHECK=true
VITE_VALHALLA_URL=https://valhalla1.openstreetmap.de
VITE_NOMINATIM_URL=https://nominatim.openstreetmap.org
VITE_TILE_SERVER_URL="https://tile.openstreetmap.org/{z}/{x}/{y}.png"
VITE_CENTER_COORDS="52.51831,13.393707"

# Possible values: auto, bicycle, pedestrian, car, truck, bus, motor_scooter, motorcycle
VITE_DEFAULT_COSTING_MODEL=bicycle

# Identifier sent as the X-Client-Id header on Valhalla requests.
# Replace CHANGE_ME with your app's identifier — the app refuses to boot otherwise.
VITE_CLIENT_ID=CHANGE_ME
